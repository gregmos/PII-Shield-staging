{
  "name": "pii-shield",
  "version": "2.0.0",
  "type": "module",
  "description": "PII Shield MCP Server — anonymize PII in legal documents (Node.js)",
  "main": "dist/server.bundle.mjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "start": "node dist/server.bundle.mjs",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:plugin": "node plugin/build-plugin.mjs",
    "local": "npx tsx src/local-app/server.ts",
    "local:watch": "npx tsx watch src/local-app/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "@xmldom/xmldom": "^0.9.0",
    "docx": "^8.0.0",
    "jszip": "^3.10.1",
    "gliner": "^0.0.19",
    "onnxruntime-node": "^1.17.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "overrides": {
    "onnxruntime-node": "$onnxruntime-node"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Grigorii Moskalev"
  },
  "license": "MIT"
}
