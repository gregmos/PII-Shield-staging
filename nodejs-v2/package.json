{
  "name": "pii-shield",
  "version": "2.0.2",
  "type": "module",
  "description": "Anonymize PII in legal documents locally — Node.js CLI (GLiNER NER, EU/UK/US patterns, .docx/.pdf/.txt, HITL review). MCP plugin distributed separately as a .mcpb.",
  "bin": {
    "pii-shield": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/cli/",
    "dist/ui/review-cli.html",
    "scripts/install-model.sh",
    "scripts/install-model.ps1",
    "scripts/install-model.bat",
    "scripts/install-model.command",
    "cli/USAGE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:ui": "vite build",
    "build:plugin": "node plugin/build-plugin.mjs",
    "build:plugin:mac": "node plugin/build-plugin.mjs --skip-testkit && node plugin/build-mac-binary.mjs && node plugin/build-testkit.mjs",
    "build:cli": "node cli/build-cli.mjs",
    "build:testkit": "node plugin/build-testkit.mjs",
    "start": "node dist/server.bundle.mjs",
    "dev": "npx tsx src/index.ts",
    "smoke": "node scripts/smoke-protocol.mjs",
    "smoke:sharp-shim": "node scripts/smoke-sharp-shim.mjs",
    "smoke:setup-panel": "node scripts/smoke-setup-panel.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "tsc:check": "tsc --noEmit",
    "tsc:check:cli": "tsc --noEmit -p tsconfig.cli.json",
    "tsc:check:ui": "tsc --noEmit -p tsconfig.ui.json",
    "tsc:check:all": "npm run tsc:check && npm run tsc:check:cli && npm run tsc:check:ui"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@ansonlai/docx-redline-js": "^0.1.4",
    "@xenova/transformers": "2.17.2",
    "@xmldom/xmldom": "^0.9.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "docx": "^8.0.0",
    "jszip": "^3.10.1",
    "gliner": "0.0.19",
    "onnxruntime-common": "1.22.0",
    "onnxruntime-node": "1.22.0",
    "onnxruntime-web": "1.22.0",
    "open": "^10.1.0",
    "pdf.js-extract": "^0.2.1",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^1.0.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "onnxruntime-node": "$onnxruntime-node",
    "onnxruntime-common": "1.22.0",
    "onnxruntime-web": "1.22.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Grigorii Moskalev"
  },
  "license": "MIT"
}
